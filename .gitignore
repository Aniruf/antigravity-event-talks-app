# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's system, not the project.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a top-level application or system, you should keep it.
#   If you're executing a library, you should ignore it.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is optionally ignored in libraries.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is optionally ignored in libraries.
#   pdm.lock

# PEP 582; used by e.g. pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

